import { config, validateConfig } from './config.js';
import { fetchLots } from './source.js';
import { formatLotAlert, TelegramClient } from './telegram.js';
import { startHealthServer } from './server.js';

const seen = new Map();
const telegram = new TelegramClient(config.telegramBotToken);
let lastCheckAt = null;
let lastError = null;
let lastLotsCount = 0;
let startedAt = new Date().toISOString();

function remember(lot) {
  seen.set(lot.id, Date.now());
  if (seen.size > 5000) {
    const sorted = [...seen.entries()].sort((a, b) => a[1] - b[1]);
    for (const [key] of sorted.slice(0, seen.size - 4000)) seen.delete(key);
  }
}

async function runCheck({ notify = true, manualChatId = null } = {}) {
  lastCheckAt = new Date().toISOString();
  const lots = await fetchLots(config);
  lastLotsCount = lots.length;
  lastError = null;

  const cheapLots = lots
    .filter((lot) => lot.rubPerKk < config.thresholdRubPerKk)
    .sort((a, b) => a.rubPerKk - b.rubPerKk);

  const newCheapLots = cheapLots.filter((lot) => !seen.has(lot.id));

  for (const lot of cheapLots) remember(lot);

  if (notify && newCheapLots.length > 0) {
    const targetChatId = manualChatId || config.telegramChatId;
    for (const lot of newCheapLots.slice(0, 10)) {
      await telegram.sendMessage(targetChatId, formatLotAlert(lot, config.thresholdRubPerKk));
    }
    if (newCheapLots.length > 10) {
      await telegram.sendMessage(targetChatId, `Найдено ещё ${newCheapLots.length - 10} новых дешёвых лотов. Показываю первые 10, чтобы не спамить.`);
    }
  }

  return { lots, cheapLots, newCheapLots };
}

async function handleCommand({ command, chatId }) {
  if (command === '/start') {
    await telegram.sendMessage(chatId, [
      '<b>Бот мониторинга лотов запущен.</b>',
      '',
      'Команды:',
      '/id - показать ID этого чата',
      '/status - статус мониторинга',
      '/check - проверить источник сейчас'
    ].join('\n'));
    return;
  }

  if (command === '/id') {
    await telegram.sendMessage(chatId, `ID этого чата: <code>${chatId}</code>\nДобавь его в Railway как TELEGRAM_CHAT_ID.`);
    return;
  }

  if (command === '/status') {
    await telegram.sendMessage(chatId, [
      '<b>Статус</b>',
      `Порог: меньше ${config.thresholdRubPerKk} ₽ за 1кк`,
      `Интервал: ${config.checkIntervalSeconds} сек.`,
      `Последняя проверка: ${lastCheckAt || 'ещё не было'}`,
      `Лотов в последней проверке: ${lastLotsCount}`,
      `Запомнено лотов: ${seen.size}`,
      `TELEGRAM_CHAT_ID задан: ${config.telegramChatId ? 'да' : 'нет'}`,
      `Последняя ошибка: ${lastError || 'нет'}`
    ].join('\n'));
    return;
  }

  if (command === '/check') {
    try {
      const result = await runCheck({ notify: false });
      const cheapest = result.cheapLots.slice(0, 5)
        .map((lot, index) => `${index + 1}. ${lot.rubPerKk} ₽/1кк - ${lot.title}${lot.url ? `\n${lot.url}` : ''}`)
        .join('\n\n');

      await telegram.sendMessage(chatId, [
        '<b>Проверка выполнена</b>',
        `Всего валидных лотов: ${result.lots.length}`,
        `Дешевле порога: ${result.cheapLots.length}`,
        cheapest ? `\n<b>Самые дешёвые:</b>\n${cheapest}` : ''
      ].filter(Boolean).join('\n'));
    } catch (error) {
      lastError = error.message;
      await telegram.sendMessage(chatId, `Ошибка проверки: <code>${error.message}</code>`);
    }
    return;
  }

  await telegram.sendMessage(chatId, 'Неизвестная команда. Используй /start.');
}

async function main() {
  validateConfig();

  startHealthServer({
    port: config.port,
    getState: () => ({
      startedAt,
      lastCheckAt,
      lastError,
      lastLotsCount,
      seenCount: seen.size
    })
  });

  telegram.startPolling(handleCommand).catch((error) => {
    console.error('[telegram] fatal polling error:', error);
  });

  if (config.startupSuppressExisting) {
    try {
      const result = await runCheck({ notify: false });
      console.log(`[monitor] startup suppressed ${result.cheapLots.length} existing cheap lots`);
    } catch (error) {
      lastError = error.message;
      console.error('[monitor] startup check failed:', error.message);
    }
  }

  setInterval(async () => {
    try {
      const result = await runCheck({ notify: true });
      console.log(`[monitor] checked=${result.lots.length} cheap=${result.cheapLots.length} new=${result.newCheapLots.length}`);
    } catch (error) {
      lastError = error.message;
      console.error('[monitor] check failed:', error.message);
      if (config.telegramChatId) {
        await telegram.sendMessage(config.telegramChatId, `Ошибка мониторинга: <code>${error.message}</code>`).catch(() => {});
      }
    }
  }, config.checkIntervalSeconds * 1000);

  console.log('[app] started');
}

process.on('SIGTERM', () => {
  console.log('[app] received SIGTERM');
  telegram.stopPolling();
  process.exit(0);
});

main().catch((error) => {
  console.error('[app] failed to start:', error.message);
  process.exit(1);
});
